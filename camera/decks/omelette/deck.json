{
  "version": 1,
  "id": "omelette",
  "name": "Omelette - range hood progression",
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30
  },
  "background": "#000000",
  "mirror": false,
  "thermal": {
    "enabled": true,
    "unit": "F",
    "coldThreshold": 300.0,
    "burnThreshold": 420.0,
    "coldLabel": "Too cold \u2014 wait for the oil to heat",
    "burnLabel": "You're burning the omelet above this!",
    "minTemp": 60.0,
    "maxTemp": 540.0
  },
  "defaults": {
    "durationSec": 4.0,
    "fit": "cover",
    "transition": {
      "type": "crossfade",
      "durationMs": 250
    }
  },
  "slides": [
    {
      "id": "omelette-001",
      "image": "images/001-dry-empty-pan.png",
      "label": "Dry empty pan",
      "mode": "manual",
      "durationSec": 9.1,
      "fit": null,
      "transition": null,
      "temperature": 75.0
    },
    {
