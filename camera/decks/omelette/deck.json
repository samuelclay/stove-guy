{
  "version": 1,
  "id": "omelette",
  "name": "Omelette - range hood progression",
  "output": {
    "width": 1920,
    "height": 1080,
    "fps": 30
  },
  "background": "#000000",
  "mirror": false,
  "defaults": {
    "durationSec": 4.0,
    "fit": "cover",
    "transition": {
      "type": "crossfade",
      "durationMs": 250
    }
  },
  "slides": [
